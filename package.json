{
  "name": "youtube-focus",
  "version": "1.0.0",
  "description": "YouTube without distractions. No recommendations, no noise — just what you searched for.",
  "main": "src/index.js",
  "private": true,
  "scripts": {
    "start":     "node src/index.js",
    "start:web": "node src/web.js",
    "start:api": "node src/api.js",
    "dev":       "node --watch src/index.js",
    "docker:build": "docker compose build",
    "docker:up":    "docker compose up -d",
    "docker:down":  "docker compose down",
    "docker:logs":  "docker compose logs -f"
  },
  "keywords": [
    "youtube",
    "focus",
    "minimal",
    "no-recommendations",
    "innertube",
    "zero-dependency"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {},
  "license": "MIT"
}
