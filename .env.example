# ─────────────────────────────────────────────────────────────────────────────
# YouTube Focus — environment configuration
# Copy this file to `.env` and edit values as needed:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Runtime environment (`development` | `production`)
NODE_ENV=development

# ── Web service (serves the HTML/CSS/JS frontend) ────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=12345

# ── API service (proxies YouTube Innertube) ──────────────────────────────────
API_HOST=127.0.0.1
API_PORT=12346

# Public URL of the API as seen by the browser. Leave blank to derive it from
# the incoming request (recommended for local dev). Set explicitly when running
# behind a reverse proxy or on a different host.
# API_PUBLIC_URL=http://localhost:12346

# ── Innertube client configuration ───────────────────────────────────────────
# These mirror what youtube.com embeds in its own page source. If requests
# start failing, grab fresh values from DevTools:
#   Network → any /youtubei/v1/ request → Request Payload → context.client
# INNERTUBE_API_KEY=AIzaSyAO_FJ2SlqU8Q4STEHLGCilw_Y9_11qcW8
# INNERTUBE_CLIENT_VERSION=2.20260521.00.00
INNERTUBE_HL=en
INNERTUBE_GL=US
INNERTUBE_TIMEOUT_MS=10000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin allowed to call the API. Use `*` for development; lock to your
# frontend's origin in production (e.g. https://focus.example.com).
CORS_ALLOW_ORIGIN=*
